APP_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:5173

LLM_PROVIDER=Agnes
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-2.0-flash
LLM_API_KEY=
# 可选：多 API 池。按数组顺序调用，前面的不可用才尝试后面的。
# LLM_ENDPOINTS_JSON=[{"name":"agnes","base_url":"https://apihub.agnes-ai.com/v1","model":"agnes-2.0-flash","api_key":"sk-xxx","enabled":true},{"name":"deepseek","base_url":"https://api.deepseek.com/v1","model":"deepseek-chat","api_key":"sk-yyy","enabled":true}]

EMBEDDING_PROVIDER=SiliconFlow
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=

INTERVIEWER_CODE_HASH=
DAILY_TOKEN_BUDGET_RMB=10
PRIORITY_DAILY_TOKEN_BUDGET_RMB=20

MAX_UPLOAD_MB=5
MAX_QUESTION_CHARS=2000
MAX_SESSION_CHARS=300000
RAG_TTL_SECONDS=7200
SUMMARY_TTL_SECONDS=86400

MAX_GLOBAL_RUNNING=2
MAX_GUEST_RUNNING=1
MAX_INTERVIEWER_RUNNING=1
MAX_GUEST_QUEUE=20
MAX_PRIORITY_QUEUE=5
